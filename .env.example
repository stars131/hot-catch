NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

DATABASE_URL="postgresql://xhs:xhs_password@127.0.0.1:5432/xhs_benchmark?schema=public"
POSTGRES_USER=xhs
POSTGRES_PASSWORD=xhs_password
POSTGRES_DB=xhs_benchmark
POSTGRES_PORT=5432

AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"
DEV_MOCK_USER_EMAIL="dev@example.com"
DEV_MOCK_USER_NAME="Dev User"

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

XHS_FETCH_PROVIDER=mock
XHS_THIRD_PARTY_API_KEY=
XHS_THIRD_PARTY_BASE_URL=

# Hotspot API-aggregator style cookie backends.
# Keep cookies server-side only. Prefer *_UPSTREAM when you run a small parser service
# that already normalizes data to { data: [{ title, url, hot, desc }] }.
HOTSPOT_XIAOHONGSHU_COOKIE=
HOTSPOT_XIAOHONGSHU_UPSTREAM=
HOTSPOT_KUAISHOU_COOKIE=
HOTSPOT_KUAISHOU_UPSTREAM=
HOTSPOT_HUPU_COOKIE=
HOTSPOT_HUPU_UPSTREAM=
HOTSPOT_36KR_COOKIE=
HOTSPOT_36KR_UPSTREAM=
HOTSPOT_QQ_NEWS_COOKIE=
HOTSPOT_QQ_NEWS_UPSTREAM=
HOTSPOT_SSPAI_COOKIE=
HOTSPOT_SSPAI_UPSTREAM=
HOTSPOT_SO360_COOKIE=
HOTSPOT_SO360_UPSTREAM=
HOTSPOT_SOGOU_COOKIE=
HOTSPOT_SOGOU_UPSTREAM=
HOTSPOT_SINA_COOKIE=
HOTSPOT_SINA_UPSTREAM=

MAX_INPUT_LENGTH=12000
MAX_BENCHMARK_ACCOUNTS_PER_ANALYSIS=5
XHS_FETCH_CACHE_HOURS=24
