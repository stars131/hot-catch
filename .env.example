NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

DATABASE_URL="postgresql://xhs:xhs_password@127.0.0.1:5432/xhs_benchmark?schema=public"
POSTGRES_USER=xhs
POSTGRES_PASSWORD=xhs_password
POSTGRES_DB=xhs_benchmark
POSTGRES_PORT=5432

AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="星迹内容助手 <noreply@example.com>"
DEV_AUTH_BYPASS=1
DEV_MOCK_USER_EMAIL="dev@example.com"
DEV_MOCK_USER_NAME="Dev User"

# 32 random bytes encoded as base64. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=
REDIS_URL=redis://127.0.0.1:6379
WORKER_CONCURRENCY=4

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

TIKHUB_BASE_URL=https://api.tikhub.io
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_WORKSPACE_ID=
MEDIA_TEMP_ROOT=
MEDIA_DOWNLOAD_MAX_MB=500
AITO_EARN_BASE_URL=https://aitoearn.cn
# 发布供应商执行模式：开发/测试默认 mock（本地状态机+契约夹具，绝不调用真实 AiToEarn）。
# 生产环境强制 real；只有显式设置 real 才会走真实供应商（未来真实验收时手动开启）。
# PUBLISH_PROVIDER_MODE=mock
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
# Agent Reach 的固定 web 渠道调用。开启后，Worker 会在 Firecrawl 失败时尝试 Jina Reader。
# 源链接会发送给该外部读取服务；确认数据流与服务条款后再开启。
AGENT_REACH_ENABLED=0
PROVIDER_TIMEOUT_MS=30000

XHS_FETCH_PROVIDER=mock
XHS_THIRD_PARTY_API_KEY=
XHS_THIRD_PARTY_BASE_URL=

# C14 staged rollout. Enable in preview first, then production after migration.
FOREIGN_PLATFORM_CREATION_ENABLED=0
UI_I18N_ENABLED=1
# Development-only opt-in for legacy shared hotspot source cookies. Production ignores it.
ALLOW_SHARED_HOTSPOT_CREDENTIALS=0

# Optional hotspot fallbacks. All catalog sources work through public endpoints by default.
# Keep optional cookies server-side only. Prefer *_UPSTREAM for a self-hosted parser that
# normalizes data to { data: [{ title, url, hot, desc }] } when a public route is restricted.
HOTSPOT_XIAOHONGSHU_COOKIE=
HOTSPOT_XIAOHONGSHU_UPSTREAM=
HOTSPOT_KUAISHOU_COOKIE=
HOTSPOT_KUAISHOU_UPSTREAM=
HOTSPOT_HUPU_COOKIE=
HOTSPOT_HUPU_UPSTREAM=
HOTSPOT_36KR_COOKIE=
HOTSPOT_36KR_UPSTREAM=
HOTSPOT_QQ_NEWS_COOKIE=
HOTSPOT_QQ_NEWS_UPSTREAM=
HOTSPOT_SSPAI_COOKIE=
HOTSPOT_SSPAI_UPSTREAM=
HOTSPOT_SOGOU_COOKIE=
HOTSPOT_SOGOU_UPSTREAM=
HOTSPOT_SINA_COOKIE=
HOTSPOT_SINA_UPSTREAM=

MAX_INPUT_LENGTH=12000
MAX_BENCHMARK_ACCOUNTS_PER_ANALYSIS=5
XHS_FETCH_CACHE_HOURS=24
